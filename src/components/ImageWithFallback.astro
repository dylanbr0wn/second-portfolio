---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  width?: number;
  class?: string;
  [key: string]: unknown;
}

const { src, alt, class: className, width, ...rest } = Astro.props;
const uid = `imgwf_${Math.random().toString(36).slice(2, 9)}`;

const aspectRatio = src.width / src.height;
const containerStyles = width
  ? `width: ${width}px; height: ${width / aspectRatio}px;`
  : `width: ${src.width}px; height: ${src.height}px;`;

console.log(containerStyles)
---

<div class="relative block">
  <div
    data-skeleton={uid}
    class:list={[className, "transition-opacity absolute inset-0 pointer-events-none z-10"]}
  >
  <div class="animate-pulse bg-white/30 rounded-xl w-full h-full"></div>
</div>
  <Image
    src={src}
    alt={alt}
    class:list={[className, "opacity-0 transition-opacity duration-500 z-20"]}
    data-imgwf={uid}
    {...rest}
  />
</div>

<script>
  function setupImage(img: HTMLImageElement) {
    const uid = img.dataset.imgwf;
    if (!uid) return;
    const skeleton = document.querySelector(`[data-skeleton="${uid}"]`);
    if (!skeleton) return;

    function reveal() {
      img.style.opacity = "1";
      (skeleton as HTMLElement).style.transition = "opacity 0.5s";
      (skeleton as HTMLElement).style.opacity = "0";
      setTimeout(() => skeleton?.remove(), 500);
    }

    if (img.complete && img.naturalWidth > 0) {
      reveal();
    } else {
      img.addEventListener("load", reveal, { once: true });
    }
  }

  document
    .querySelectorAll<HTMLImageElement>("[data-imgwf]")
    .forEach(setupImage);

  new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      for (const node of mutation.addedNodes) {
        if (!(node instanceof Element)) continue;
        if (node.matches("[data-imgwf]"))
          setupImage(node as HTMLImageElement);
        node
          .querySelectorAll<HTMLImageElement>("[data-imgwf]")
          .forEach(setupImage);
      }
    }
  }).observe(document.body, { childList: true, subtree: true });
</script>
